{
  "name": "api",
  "versi  on": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "nodemon --exec \"node -r esbuild-register ./src/main.ts\" -e .ts",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\" --max-warnings 0",
    "start": "node -r esbuild-register ./src/main.ts",
    "format": "prettier --write .",
    "test:watch": "vitest watch",
    "test": "vitest run",
    "format:biome": "npx @biomejs/biome format --write ./src",
    "prisma:generate": "prisma generate --schema=src/shared/db-prisma/prisma/schema.prisma",
    "prisma:db:pull": "prisma db pull --schema=src/shared/db-prisma/prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema=src/shared/db-prisma/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-async-handler": "1.2.0",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "12.2.0",
    "handlebars": "4.7.8",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "nodemailer": "6.9.14",
    "openai": "^4.104.0",
    "prisma": "^6.8.2",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "3.13.0",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^6.4.16",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.20.1",
    "esbuild-register": "^3.5.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3",
    "vitest": "^3.0.9"
  }
}
